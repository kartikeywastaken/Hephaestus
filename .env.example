# Hephaestus local environment config
# Copy this file to .env.local and fill values locally.
# Never commit .env.local.

# Groq cloud provider
GROQ_API_KEY=

# Alternative Groq key name
# HEPHAESTUS_GROQ_API_KEY=

# Ollama local provider
OLLAMA_HOST=http://localhost:11434
HEPHAESTUS_AGENT_MODEL=llama3.3:70b
